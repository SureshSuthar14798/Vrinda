{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for patients, doctors, and admins",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"] },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Doctor-specific profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "specialization": { "type": "string" },
        "experience": { "type": "string" },
        "bio": { "type": "string" },
        "department": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["uid", "specialization", "department"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Appointment booking details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "patientName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timeSlot": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "department": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "timeSlot", "status"]
    },
    "MedicalRecord": {
      "title": "MedicalRecord",
      "description": "Patient medical records and prescriptions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["report", "prescription"] },
        "description": { "type": "string" },
        "fileUrl": { "type": "string" }
      },
      "required": ["patientId", "doctorId", "date", "type"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/doctors/{uid}": {
      "schema": "Doctor",
      "description": "Doctor profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointment records"
    },
    "/medicalRecords/{recordId}": {
      "schema": "MedicalRecord",
      "description": "Medical records and prescriptions"
    }
  }
}
